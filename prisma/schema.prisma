generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Idea {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("Not Started")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
